@baseUrl = http://localhost:3000
@accessToken = СЮДИ_ВСТАВИШ_ACCESS_TOKEN_ПІСЛЯ_ЛОГІНУ
@refreshToken = СЮДИ_ВСТАВИШ_REFRESH_TOKEN_ПІСЛЯ_ЛОГІНУ

### ==========================================
### AUTH МАРШРУТИ
### ==========================================

# 1. Реєстрація нового користувача (Успіх)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "diana_it",
  "password": "securepassword123",
  "name": "Діана"
}

###

# 2. Повторна реєстрація того самого юзера (Має повернути 409)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "diana_it",
  "password": "securepassword123",
  "name": "Діана"
}

###

# 3. Вхід користувача (Успіх - повертає токени та куку)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "diana_it",
  "password": "securepassword123"
}

###

# 4. Вхід з невірними даними (Має повернути 401 Invalid credentials)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "diana_it",
  "password": "wrongpassword"
}

###

# 5. Оновлення токена (Token Rotation)
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

# 6. Отримання профілю (Потребує токена)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}


### ==========================================
### ПЕРЕВІРКА ЗАХИСТУ ТА OWNERSHIP (ОГОЛОШЕННЯ)
### ==========================================

# 7. Створення оголошення БЕЗ токена (Має повернути 401)
POST {{baseUrl}}/announcements
Content-Type: application/json

{
  "title": "Новий крутий велосипед",
  "description": "Продам велосипед у відмінному стані, майже новий.",
  "price": 4500,
  "category": "sale",
  "contactInfo": "+380990000000"
}

###

# 8. Створення оголошення З токеном (Успіх, статус 201)
# Переконайся, що в змінній @accessToken вгорі вставлено актуальний токен!
POST {{baseUrl}}/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Крутий гірський велосипед",
  "description": "Продам велосипед у відмінному стані, 21 швидкість.",
  "price": 5500,
  "category": "sale",
  "contactInfo": "+380990000000"
}

###

# 9. Редагування власного оголошення (Успіх, міняємо ціну)
# Заміни ID у лінку на той ID, який повернувся в запиті №8 (наприклад, /1)
PATCH {{baseUrl}}/announcements/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "price": 5000
}

###

# 10. Спроба видалити або змінити чуже оголошення (Має повернути 403)
# (Для тесту потрібно створити оголошення від імені іншого юзера, або підставити ID, що не належить diana_it)
DELETE {{baseUrl}}/announcements/999
Authorization: Bearer {{accessToken}}

###

# 11. Вихід із системи (Логаут)
POST {{baseUrl}}/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}